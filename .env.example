# Application
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=change-me-in-production

# EPIAS
EPIAS_USERNAME=
EPIAS_PASSWORD=

# Email (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# MLflow (PostgreSQL backend: use DATABASE_URL_SYNC value for persistence)
# MLFLOW_TRACKING_URI=postgresql+psycopg2://forecast_user:devpassword@localhost:5432/energy_forecast
MLFLOW_TRACKING_URI=http://localhost:5000

# AWS (production)
AWS_S3_BUCKET=energy-forecast-models
AWS_REGION=eu-west-1

# Database (optional — leave empty for in-memory mode)
# Local Docker: docker compose up -d && alembic upgrade head
DATABASE_URL=postgresql+asyncpg://forecast_user:devpassword@localhost:5432/energy_forecast
DATABASE_URL_SYNC=postgresql+psycopg2://forecast_user:devpassword@localhost:5432/energy_forecast

# Google Drive Backup (optional)
GDRIVE_ENABLED=false
GDRIVE_CREDENTIALS_PATH=credentials/gdrive-sa.json
GDRIVE_ROOT_FOLDER_ID=
